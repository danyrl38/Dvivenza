# -----------------------------------------------------------------------------
# Dvivenza — Variables de entorno
# Copia este archivo como `.env.local` y completa con tus credenciales.
# En Vercel, agrégalas en Project Settings → Environment Variables.
# -----------------------------------------------------------------------------

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Clave de servicio — SOLO en el servidor. Nunca la expongas al cliente.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Nombre del bucket de Storage donde se guardan las referencias
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=referencias

# Datos de contacto públicos
NEXT_PUBLIC_WHATSAPP_NUMBER=5215555555555
NEXT_PUBLIC_CONTACT_EMAIL=hola@dvivenza.com
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/dvivenza
NEXT_PUBLIC_TIKTOK_URL=https://tiktok.com/@dvivenza

# URL pública del sitio (para SEO / sitemap)
NEXT_PUBLIC_SITE_URL=https://dvivenza.com

# -----------------------------------------------------------------------------
# Notificaciones por email de nuevos pedidos (Resend — https://resend.com)
# Opcional: si no defines RESEND_API_KEY, no se envían correos (no rompe nada).
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_tu_api_key
# A quién avisar (si se omite, usa NEXT_PUBLIC_CONTACT_EMAIL)
ORDER_NOTIFY_EMAIL=pedidos@dvivenza.com
# Remitente verificado en Resend. Para pruebas puedes usar el de abajo:
RESEND_FROM=Dvivenza <onboarding@resend.dev>

# -----------------------------------------------------------------------------
# Panel de administración (/admin) — autenticación básica
# Define ADMIN_PASSWORD para habilitar el panel. Sin ella, /admin queda cerrado.
# -----------------------------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-contraseña
